{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Malanghub",
  "version": "0.1.0",
  "identifier": "com.malanghub.app",
  "build": {
    "beforeDevCommand": "pnpm mobile:config && pnpm dev --host 0.0.0.0",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Malanghub",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "developmentTeam": "7FCMB3QMK7"
    }
  },
  "plugins": {
    "shell": {
      "open": "((mailto:.+)|(tel:.+)|(sms:.+)|(https?://.+)|(geo:.+)|(maps:.+)|(whatsapp:.+)|(comgooglemaps:.+)|(google\\.navigation:.+))"
    },
    "deep-link": {
      "mobile": [
        {
          "scheme": ["com.malanghub.app"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["com.malanghub.app"]
      }
    }
  }
}
