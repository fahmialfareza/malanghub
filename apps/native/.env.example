VITE_API_ADDRESS=http://localhost:4000
VITE_GOOGLE_CLIENT_ID=
# Required for "Web application" OAuth clients. Leave empty for "Desktop app" clients.
VITE_GOOGLE_CLIENT_SECRET=
# Web client ID used by native Android to request an ID token for backend auth.
VITE_GOOGLE_SERVER_CLIENT_ID=
# Native Google clients from Google Cloud Console.
VITE_GOOGLE_ANDROID_CLIENT_ID=
VITE_GOOGLE_IOS_CLIENT_ID=
# iOS OAuth redirect for the native ASWebAuthenticationSession flow.
VITE_GOOGLE_IOS_REDIRECT_URI=com.malanghub.app:/oauth2redirect/google
VITE_TINY_API_KEY=
VITE_SENTRY_DSN=
